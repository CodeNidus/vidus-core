{
  "name": "vidus-core",
  "version": "1.1.0",
  "description": "Vidus video conference core package",
  "license": "ISC",
  "author": "Code Nidus",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.js --format esm,cjs --external @tensorflow/*,@mediapipe/*,@ffmpeg/*,axios,peerjs,socket.io-client",
    "dev": "tsup src/index.js --watch --format esm,cjs --external @tensorflow/*,@mediapipe/*,@ffmpeg/*,axios,peerjs,socket.io-client",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@mediapipe/face_detection": "^0.4.1646425229",
    "@mediapipe/selfie_segmentation": "^0.1.1675465747",
    "@mediapipe/tasks-vision": "^0.10.35",
    "axios": "^1.10.0",
    "peerjs": "^1.5.5",
    "socket.io-client": "^4.8.1"
  },
  "peerDependencies": {
    "@tensorflow-models/body-segmentation": "^1.0.2",
    "@tensorflow-models/face-detection": "^1.0.3",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
	"typescript": "^7.0.2"
  },
  "keywords": [
    "video",
    "conference"
  ]
}
